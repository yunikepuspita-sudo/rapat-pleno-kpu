# Salin file ini menjadi `.env` lalu isi dengan kredensial Supabase Anda.
# Ambil dari: Supabase Dashboard → Project Settings → API.
#
# CATATAN KEAMANAN: anon key memang aman dipakai di sisi browser
# (dilindungi Row-Level Security). JANGAN pernah menaruh service_role key di sini.

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi....

# ── Integrasi WhatsApp (opsional) ───────────────────────────────────────────
# Nomor customer care, format internasional TANPA "+", spasi, atau "-".
# Contoh Indonesia: 08123456789  →  628123456789
VITE_WA_PHONE=6281234567890
#
# Tautan Saluran WhatsApp (Channel). Buat di WhatsApp → tab Pembaruan →
# "+" → Saluran baru, lalu salin tautan bagikan.
# Selama masih placeholder, banner & tombol saluran otomatis disembunyikan.
VITE_WA_CHANNEL_URL=https://whatsapp.com/channel/0029Vb80PMo8V0tuv79TCi1g
VITE_WA_CHANNEL_NAME=E-Pustaka Pemilu
#
# URL publik situs (untuk menyusun tautan buku yang dibagikan).
VITE_SITE_URL=https://pustaka.yunikepuspita.com
