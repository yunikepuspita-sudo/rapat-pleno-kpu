# Salin ke .env — JANGAN commit nilai sungguhan.
DATABASE_URL=postgresql+psycopg://petasuara:petasuara-dev@localhost:5432/petasuara
REDIS_URL=redis://localhost:6379/0

# Object storage (R2/MinIO)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=petasuara
S3_SECRET_KEY=petasuara-dev
S3_BUCKET_KORPUS=petasuara-korpus
S3_BUCKET_DELIVERABLE=petasuara-deliverable

# LLM-annotator (posisi pesan) — biaya dianggarkan per engagement
LLM_API_KEY=
LLM_MODEL=

# Ambang gerbang QC (Cetak Biru VI) — jangan turunkan tanpa keputusan direktur riset
QC_AMBANG_KAPPA=0.70
QC_AMBANG_MACRO_F1=0.75
